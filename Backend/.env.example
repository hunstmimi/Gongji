APP_ENV=local
DATABASE_URL=postgresql://gongji:gongji-password@127.0.0.1:5432/gongji
COMPUTE_RENTAL_DB_PATH=compute_rental.db
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COMPUTE_RENTAL_SSH_USERNAME_PREFIX=rent
COMPUTE_RENTAL_SSH_PORT_BASE=22000
COMPUTE_RENTAL_SSH_PASSWORD_SEED=local-demo-rental-secret
COMPUTE_RENTAL_AGENT_BASE_URL=
COMPUTE_RENTAL_AGENT_PORT=18080
COMPUTE_RENTAL_AGENT_TOKEN=local-agent-token
COMPUTE_RENTAL_AGENT_DRY_RUN=false
COMPUTE_RENTAL_AGENT_DEFAULT_IMAGE=gongji/ascend-ssh:latest
COMPUTE_RENTAL_CPU_PER_CARD=8
COMPUTE_RENTAL_MEMORY_PER_CARD_GB=64
COMPUTE_RENTAL_SHM_PER_CARD_GB=16
